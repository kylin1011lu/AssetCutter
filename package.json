{
  "name": "asset-cutter",
  "version": "0.1.0",
  "description": "Local-first browser workbench for cutting source images into reusable PNG assets.",
  "private": true,
  "license": "MIT",
  "keywords": [
    "asset-cutter",
    "image-crop",
    "png",
    "sprites",
    "vite",
    "react",
    "konva"
  ],
  "overrides": {
    "esbuild": "0.28.1"
  },
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "build:single": "tsc -b && ASSET_CUTTER_SINGLE_FILE=1 vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "konva": "^10.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-konva": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^25.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^27.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  }
}
